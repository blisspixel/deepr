{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blisspixel/deepr/docs/schemas/claim-verification-v1.json",
  "title": "Deepr Claim Verification v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "kind",
    "contract",
    "input",
    "prompt",
    "model",
    "summary",
    "decisions",
    "compiler",
    "generated_at"
  ],
  "properties": {
    "schema_version": {"const": "deepr-claim-verification-v1"},
    "kind": {"const": "deepr.expert.claim_verification"},
    "contract": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "read_only",
        "derived_view",
        "semantic_judgment",
        "model_calls",
        "cost_usd",
        "writes_graph"
      ],
      "properties": {
        "read_only": {"const": true},
        "derived_view": {"const": true},
        "semantic_judgment": {"const": true},
        "model_calls": {"const": true},
        "cost_usd": {"type": "number", "minimum": 0},
        "writes_graph": {"const": false},
        "breaking_changes_require_new_schema_version": {"const": true}
      }
    },
    "input": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "claim_extraction_schema_version",
        "claim_extraction_kind",
        "candidate_count",
        "ready_candidate_count"
      ],
      "properties": {
        "claim_extraction_artifact": {"type": "string"},
        "claim_extraction_schema_version": {"type": "string"},
        "claim_extraction_kind": {"type": "string"},
        "candidate_count": {"type": "integer", "minimum": 0},
        "ready_candidate_count": {"type": "integer", "minimum": 0}
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "prompt_version",
        "prompt_hash",
        "prompt_text_included",
        "response_schema_version",
        "response_schema_ref",
        "structured_output_mode",
        "app_side_schema_validation_required"
      ],
      "properties": {
        "prompt_version": {"type": "string"},
        "prompt_ref": {"type": "string"},
        "prompt_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "prompt_text_included": {"const": false},
        "response_schema_version": {"const": "deepr-claim-verification-v1"},
        "response_schema_ref": {"type": "string"},
        "structured_output_mode": {"type": "string"},
        "app_side_schema_validation_required": {"const": true}
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": true,
      "required": ["provider", "model", "capacity_source", "raw_response_hash", "response_failure"],
      "properties": {
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "capacity_source": {"type": "string"},
        "raw_response_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
        "response_failure": {"type": "string"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "status",
        "parsed_decision_count",
        "ready_for_commit_envelope_count",
        "blocked_decision_count",
        "recall_case_candidate_count",
        "failure_reasons"
      ],
      "properties": {
        "status": {"enum": ["ready_for_commit_envelope", "blocked", "empty"]},
        "parsed_decision_count": {"type": "integer", "minimum": 0},
        "ready_for_commit_envelope_count": {"type": "integer", "minimum": 0},
        "blocked_decision_count": {"type": "integer", "minimum": 0},
        "recall_case_candidate_count": {"type": "integer", "minimum": 0},
        "failure_reasons": {"type": "array", "items": {"type": "string"}}
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "candidate_id",
          "claim_kind",
          "state_policy",
          "verdicts",
          "model_judgment",
          "readiness",
          "commit_gate"
        ],
        "properties": {
          "candidate_id": {"type": "string"},
          "claim_kind": {"type": "string"},
          "state_policy": {"type": "object", "additionalProperties": true},
          "verdicts": {
            "type": "object",
            "additionalProperties": true,
            "required": ["support", "contradiction", "deduplication", "temporal_scope"],
            "properties": {
              "support": {"enum": ["supported", "refuted", "insufficient", "not_applicable", "unverified"]},
              "contradiction": {"enum": ["none", "possible", "contradiction", "unverified"]},
              "deduplication": {"enum": ["new", "same_as_existing", "uncertain", "unverified"]},
              "temporal_scope": {"enum": ["valid", "unclear", "outdated", "not_applicable"]}
            }
          },
          "model_judgment": {"type": "object", "additionalProperties": true},
          "edge_decisions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["source_candidate_id", "target_candidate_id", "edge_type"],
              "properties": {
                "source_candidate_id": {"type": "string"},
                "target_candidate_id": {"type": "string"},
                "edge_type": {"enum": ["supports", "contradicts", "enables", "derived_from"]},
                "confidence": {"type": "number", "minimum": 0, "maximum": 1},
                "rationale": {"type": "string"},
                "temporal": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "valid_from": {"type": "string"},
                    "valid_until": {"type": "string"},
                    "observed_at": {"type": "string"},
                    "temporal_scope": {"type": "string"}
                  }
                }
              }
            }
          },
          "edge_decision_failures": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["index", "failure_reasons"],
              "properties": {
                "index": {"type": "integer", "minimum": 0},
                "failure_reasons": {"type": "array", "items": {"type": "string"}}
              }
            }
          },
          "recall_context": {
            "type": "object",
            "additionalProperties": true,
            "required": ["routing", "semantic_verdict", "writes_graph", "candidate_count", "candidates"],
            "properties": {
              "routing": {"const": "candidate_only"},
              "semantic_verdict": {"const": false},
              "writes_graph": {"const": false},
              "candidate_count": {"type": "integer", "minimum": 0},
              "candidates": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": [
                    "item_id",
                    "kind",
                    "domain",
                    "text",
                    "score",
                    "method",
                    "matched_terms",
                    "metadata",
                    "verdict",
                    "guidance"
                  ],
                  "properties": {
                    "item_id": {"type": "string"},
                    "kind": {"type": "string"},
                    "domain": {"type": "string"},
                    "text": {"type": "string"},
                    "score": {"type": "number", "minimum": 0, "maximum": 1},
                    "method": {"type": "string"},
                    "matched_terms": {"type": "array", "items": {"type": "string"}},
                    "metadata": {"type": "object", "additionalProperties": true},
                    "verdict": {"const": "candidate_only"},
                    "guidance": {"const": "routing_only"}
                  }
                }
              }
            }
          },
          "recall_case_candidate": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "schema_version",
              "kind",
              "case_id",
              "source_id",
              "source_kind",
              "source_reason",
              "source_candidate_id",
              "contract",
              "input",
              "operator_instruction"
            ],
            "properties": {
              "schema_version": {"const": "deepr-recall-eval-case-candidate-v1"},
              "kind": {"const": "deepr.eval.recall_case_candidate"},
              "case_id": {"type": "string"},
              "source_id": {"type": "string"},
              "source_kind": {"const": "claim_verification_decision"},
              "source_reason": {
                "enum": ["duplicate_existing_belief", "contradiction_unresolved", "temporal_scope_rejected"]
              },
              "source_candidate_id": {"type": "string"},
              "contract": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "cost_usd",
                  "writes_state",
                  "writes_graph",
                  "writes_beliefs",
                  "writes_belief_vectors",
                  "semantic_verdict",
                  "candidate_only",
                  "requires_operator_relevance_review",
                  "auto_record",
                  "derived_from"
                ],
                "properties": {
                  "cost_usd": {"const": 0.0},
                  "writes_state": {"const": false},
                  "writes_graph": {"const": false},
                  "writes_beliefs": {"const": false},
                  "writes_belief_vectors": {"const": false},
                  "semantic_verdict": {"const": false},
                  "candidate_only": {"const": true},
                  "requires_operator_relevance_review": {"const": true},
                  "auto_record": {"const": false},
                  "derived_from": {"const": "deepr-claim-verification-v1"}
                }
              },
              "input": {
                "type": "object",
                "additionalProperties": true,
                "required": [
                  "query_hash",
                  "query_preview",
                  "candidate_belief_ids",
                  "claim_candidate_id",
                  "verifier_failure_reasons",
                  "verdicts"
                ],
                "properties": {
                  "query_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
                  "query_preview": {"type": "string"},
                  "candidate_belief_ids": {"type": "array", "items": {"type": "string"}},
                  "claim_candidate_id": {"type": "string"},
                  "claim_kind": {"type": "string"},
                  "recall_candidate_count": {"type": "integer", "minimum": 0},
                  "verifier_failure_reasons": {"type": "array", "items": {"type": "string"}},
                  "verdicts": {"type": "object", "additionalProperties": true}
                }
              },
              "operator_instruction": {"type": "string"}
            }
          },
          "readiness": {
            "type": "object",
            "additionalProperties": true,
            "required": ["ready_for_commit_envelope", "failure_reasons"],
            "properties": {
              "ready_for_commit_envelope": {"type": "boolean"},
              "failure_reasons": {"type": "array", "items": {"type": "string"}}
            }
          },
          "commit_gate": {
            "type": "object",
            "additionalProperties": true,
            "required": ["status", "writes_graph", "requires_commit_envelope"],
            "properties": {
              "status": {"enum": ["ready_for_commit_envelope", "blocked"]},
              "writes_graph": {"const": false},
              "requires_commit_envelope": {"const": true}
            }
          }
        }
      }
    },
    "compiler": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "stage",
        "previous_stage",
        "next_stage",
        "graph_writes_require_commit_envelope"
      ],
      "properties": {
        "stage": {"const": "claim_verification"},
        "previous_stage": {"const": "semantic_claim_extraction"},
        "next_stage": {"const": "graph_commit_envelope"},
        "next_stage_requires_model_judgment": {"const": false},
        "graph_writes_require_commit_envelope": {"const": true}
      }
    },
    "generated_at": {"type": "string"}
  }
}
