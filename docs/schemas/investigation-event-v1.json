{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blisspixel/deepr/docs/schemas/investigation-event-v1.json",
  "title": "Deepr Investigation Event v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "kind", "run_id", "sequence", "event_type", "phase", "status", "detail", "created_at"],
  "properties": {
    "schema_version": {"const": "deepr-investigation-event-v1"},
    "kind": {"const": "deepr.expert.investigation_event"},
    "run_id": {"type": "string", "minLength": 1},
    "sequence": {"type": "integer", "minimum": 1},
    "event_type": {"type": "string", "minLength": 1},
    "phase": {"enum": ["preflight", "charters", "research", "positions", "discussion", "revisions", "check", "synthesis", "learning", "complete"]},
    "status": {"enum": ["planned", "running", "paused", "cancelling", "completed", "completed_partial", "cancelled", "budget_exhausted", "verifier_failed", "failed"]},
    "detail": {"type": "object"},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
