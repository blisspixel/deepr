{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blisspixel/deepr/docs/schemas/expert-blueprint-preflight-v1.json",
  "title": "Deepr Expert Blueprint Preflight v1",
  "description": "A zero-call structural preparation artifact for an unreviewed blueprint draft. Structural validity is not semantic quality, human review, operator attestation, or scope authority.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "status",
    "contract",
    "draft_content_hash",
    "draft",
    "structural_summary",
    "review_questions",
    "next_step"
  ],
  "properties": {
    "schema_version": {"const": "deepr-expert-blueprint-preflight-v1"},
    "kind": {"const": "deepr.expert.blueprint_preflight"},
    "status": {"const": "structurally_valid_unreviewed"},
    "contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "structurally_valid",
        "semantic_quality_assessed",
        "human_review_claimed",
        "operator_attestation_present",
        "authoritative_for_scope",
        "writes_canonical_state",
        "model_calls",
        "provider_calls",
        "network_access",
        "cost_usd"
      ],
      "properties": {
        "structurally_valid": {"const": true},
        "semantic_quality_assessed": {"const": false},
        "human_review_claimed": {"const": false},
        "operator_attestation_present": {"const": false},
        "authoritative_for_scope": {"const": false},
        "writes_canonical_state": {"const": false},
        "model_calls": {"const": 0},
        "provider_calls": {"const": 0},
        "network_access": {"const": false},
        "cost_usd": {"const": 0.0}
      }
    },
    "draft_content_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "draft": {"$ref": "#/$defs/blueprint_draft"},
    "structural_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "non_goal_count",
        "decision_use_case_count",
        "acceptance_case_count",
        "acceptance_cases_with_failure_conditions",
        "initial_question_count",
        "preferred_source_type_count",
        "excluded_source_count",
        "primary_sources_required",
        "volatility",
        "update_cadence_days"
      ],
      "properties": {
        "non_goal_count": {"type": "integer", "minimum": 0, "maximum": 50},
        "decision_use_case_count": {"type": "integer", "minimum": 1, "maximum": 50},
        "acceptance_case_count": {"type": "integer", "minimum": 1, "maximum": 100},
        "acceptance_cases_with_failure_conditions": {"type": "integer", "minimum": 0, "maximum": 100},
        "initial_question_count": {"type": "integer", "minimum": 1, "maximum": 50},
        "preferred_source_type_count": {"type": "integer", "minimum": 0, "maximum": 30},
        "excluded_source_count": {"type": "integer", "minimum": 0, "maximum": 50},
        "primary_sources_required": {"type": "boolean"},
        "volatility": {"enum": ["slow", "medium", "fast"]},
        "update_cadence_days": {"type": "integer", "minimum": 1, "maximum": 3650}
      }
    },
    "review_questions": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 1000}
    },
    "next_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "review_required",
        "attestation_flag",
        "claim_recorded_on_apply",
        "reviewer_identity_will_be_verified"
      ],
      "properties": {
        "review_required": {"const": true},
        "attestation_flag": {"const": "--attested-by"},
        "claim_recorded_on_apply": {"const": "scope_and_acceptance_review_completed"},
        "reviewer_identity_will_be_verified": {"const": false}
      }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,79}$"
    },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 20,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1, "maxLength": 2000}
    },
    "decision_use_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "success_criteria"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "question": {"type": "string", "minLength": 1, "maxLength": 4000},
        "success_criteria": {"$ref": "#/$defs/criteria"}
      }
    },
    "acceptance_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "question", "success_criteria", "failure_conditions"],
      "properties": {
        "id": {"$ref": "#/$defs/identifier"},
        "question": {"type": "string", "minLength": 1, "maxLength": 4000},
        "success_criteria": {"$ref": "#/$defs/criteria"},
        "failure_conditions": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 2000}
        }
      }
    },
    "source_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_sources_required", "preferred_source_types", "excluded_sources"],
      "properties": {
        "primary_sources_required": {"type": "boolean"},
        "preferred_source_types": {
          "type": "array",
          "maxItems": 30,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 2000}
        },
        "excluded_sources": {
          "type": "array",
          "maxItems": 50,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 2000}
        }
      }
    },
    "blueprint_draft": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "kind",
        "expert_name",
        "mission",
        "non_goals",
        "decision_use_cases",
        "source_policy",
        "volatility",
        "update_cadence_days",
        "initial_questions",
        "acceptance_cases"
      ],
      "properties": {
        "schema_version": {"const": "deepr-expert-blueprint-draft-v1"},
        "kind": {"const": "deepr.expert.blueprint_draft"},
        "expert_name": {"type": "string", "minLength": 1, "maxLength": 120},
        "mission": {"type": "string", "minLength": 1, "maxLength": 4000},
        "non_goals": {
          "type": "array",
          "maxItems": 50,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 2000}
        },
        "decision_use_cases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "items": {"$ref": "#/$defs/decision_use_case"}
        },
        "source_policy": {"$ref": "#/$defs/source_policy"},
        "volatility": {"enum": ["slow", "medium", "fast"]},
        "update_cadence_days": {"type": "integer", "minimum": 1, "maximum": 3650},
        "initial_questions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 50,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 2000}
        },
        "acceptance_cases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {"$ref": "#/$defs/acceptance_case"}
        }
      }
    }
  }
}
