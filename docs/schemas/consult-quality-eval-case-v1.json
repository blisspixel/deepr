{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/blisspixel/deepr/docs/schemas/consult-quality-eval-case-v1.json",
  "title": "Deepr Consult Quality Eval Case v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "kind",
    "case_id",
    "source_trace_id",
    "category",
    "contract",
    "input",
    "rubric",
    "failure_labels",
    "acceptance_policy"
  ],
  "properties": {
    "schema_version": {"const": "deepr-consult-quality-eval-case-v1"},
    "kind": {"const": "deepr.eval.consult_quality_case"},
    "case_id": {"type": "string"},
    "source_trace_id": {"type": "string"},
    "category": {"const": "consult_semantic_quality"},
    "contract": {
      "type": "object",
      "required": [
        "cost_usd",
        "writes_state",
        "semantic_verdict",
        "requires_human_or_calibrated_model_judge",
        "lexical_verdict_allowed"
      ],
      "properties": {
        "cost_usd": {"type": "number", "minimum": 0},
        "writes_state": {"const": false},
        "semantic_verdict": {"const": false},
        "requires_human_or_calibrated_model_judge": {"const": true},
        "lexical_verdict_allowed": {"const": false}
      },
      "additionalProperties": true
    },
    "input": {
      "type": "object",
      "required": [
        "question_hash",
        "question_preview",
        "reason",
        "capacity",
        "selected_context_count",
        "failed_checks",
        "warning_checks",
        "synthesis_status"
      ],
      "properties": {
        "question_hash": {"type": "string"},
        "question_preview": {"type": "string"},
        "reason": {"type": "string"},
        "capacity": {"type": "object"},
        "selected_context_count": {"type": "integer", "minimum": 0},
        "context_position_zones": {"type": "array", "items": {"type": "string"}},
        "middle_context_slot_count": {"type": "integer", "minimum": 0},
        "failed_checks": {"type": "array", "items": {"type": "string"}},
        "warning_checks": {"type": "array", "items": {"type": "string"}},
        "synthesis_status": {"type": "string"}
      },
      "additionalProperties": true
    },
    "rubric": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["dimension", "score_min", "score_max", "judge_question"],
        "properties": {
          "dimension": {"type": "string"},
          "score_min": {"type": "integer", "minimum": 0},
          "score_max": {"type": "integer", "minimum": 1},
          "judge_question": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "hallucination_risk_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["risk_label", "requires_semantic_judgment", "judge_question"],
        "properties": {
          "risk_label": {"type": "string"},
          "requires_semantic_judgment": {"const": true},
          "judge_question": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "failure_labels": {"type": "array", "items": {"type": "string"}},
    "acceptance_policy": {
      "type": "object",
      "required": ["minimum_mean_score", "requires_reviewer", "eligible_promotions", "never_commits_beliefs"],
      "properties": {
        "minimum_mean_score": {"type": "number", "minimum": 0},
        "requires_reviewer": {"const": true},
        "eligible_promotions": {"type": "array", "items": {"type": "string"}},
        "never_commits_beliefs": {"const": true}
      },
      "additionalProperties": true
    }
  }
}
