#!/usr/bin/env python
"""Run Deepr API server."""

import ipaddress
import logging
import os
import sys

from deepr.api.app import app


def _is_loopback(host: str) -> bool:
    if host in ("localhost", ""):
        return True
    try:
        return ipaddress.ip_address(host).is_loopback
    except ValueError:
        return False


def main():
    """Start the API server."""
    # Set up logging
    logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(levelname)s - %(message)s")

    # Get config from environment. Default to loopback for safety -- the API
    # exposes job submission, result retrieval, and provider-backed work that
    # spends operator credentials. Binding to a non-local interface without
    # DEEPR_API_TOKEN is a serious security risk (data disclosure + provider
    # spend abuse). The check below refuses to start in that configuration
    # unless the operator explicitly acknowledges the risk.
    host = os.getenv("API_HOST", "127.0.0.1")
    port = int(os.getenv("API_PORT", 5000))
    debug = os.getenv("FLASK_ENV", "production") == "development"
    api_token_set = bool(os.getenv("DEEPR_API_TOKEN", "").strip())
    allow_public = os.getenv("DEEPR_ALLOW_PUBLIC_BIND", "").strip().lower() in ("1", "true", "yes")

    if not _is_loopback(host) and not api_token_set and not allow_public:
        sys.stderr.write(
            f"ERROR: refusing to bind '{host}' without DEEPR_API_TOKEN set. The API\n"
            "exposes job submission and provider-backed research; an unauthenticated\n"
            "peer could spend your provider budget and read stored reports.\n"
            "  - Set DEEPR_API_TOKEN to require a bearer token, or\n"
            "  - Use API_HOST=127.0.0.1 (the safe default), or\n"
            "  - Set DEEPR_ALLOW_PUBLIC_BIND=1 ONLY on a trusted network after\n"
            "    you have read and accepted the risk in the documentation.\n"
        )
        sys.exit(2)

    warning = ""
    if not _is_loopback(host) and not api_token_set:
        warning = "WARNING: binding non-loopback interface WITHOUT auth - DEEPR_ALLOW_PUBLIC_BIND is set."

    print(f"""
===============================================================================

    ########   ##########  ##########  ########      #######
    ##    ##   ##          ##          ##     ##     ##    ##
    ##     ##  ########    ########    ########      ########
    ##    ##   ##          ##          ##            ##    ##
    ########   ##########  ##########  ##            ##     ##

                         API Server
              Deepr Research Automation Platform

===============================================================================

Starting server on {host}:{port}
Debug mode: {debug}
API endpoints: http://{host}:{port}/api
Health check: http://{host}:{port}/api/health
{warning}

Press Ctrl+C to stop
    """)

    try:
        app.run(host=host, port=port, debug=debug)
    except KeyboardInterrupt:
        print("\n\nShutting down API server...")
        sys.exit(0)


if __name__ == "__main__":
    main()
