# Deepr Azure Deployment Configuration

# Required by the current template, but hosted metered research remains disabled.
# The deploy script passes secure Bicep parameters through a mode-0600 temporary
# file and removes it on exit. It does not place secret values in process argv.
OPENAI_API_KEY=sk-...

# Optional stored credentials. They do not enable automatic paid fallback.
GOOGLE_API_KEY=
XAI_API_KEY=

# Budget limits (USD)
DEEPR_BUDGET_DAILY=10
DEEPR_BUDGET_MONTHLY=10

# Azure Configuration
DEEPR_RESOURCE_GROUP=deepr-rg
DEEPR_LOCATION=eastus
DEEPR_ENVIRONMENT=prod
