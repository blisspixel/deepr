# Deepr GCP Deployment Configuration

# Required: GCP Project ID
GCP_PROJECT_ID=your-project-id

# Required: ID of a pre-created Secret Manager secret containing the OpenAI key.
# Pass the secret ID, not the secret value. Provider keys never enter Terraform
# variables or state.
DEEPR_GCP_OPENAI_SECRET_ID=deepr-prod-openai-key

# Budget limits (USD)
DEEPR_BUDGET_DAILY=10
DEEPR_BUDGET_MONTHLY=10

# GCP Configuration
GCP_REGION=us-central1
DEEPR_ENVIRONMENT=prod
