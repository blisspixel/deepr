# Copy to .env before running docker compose from this directory.

# Host directory mounted into the container as /data. This should be the Deepr
# data directory that owns experts, reports, security keys, and remote audit
# records.
DEEPR_HOST_DATA_DIR=../../data

# Provider keys are optional. Leave them unset for read-only hosted MCP access
# and zero-spend smoke validation.
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
# XAI_API_KEY=
# ANTHROPIC_API_KEY=
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=

# Deepr runtime logging.
DEEPR_MCP_HTTP_MAX_CONCURRENCY=32
DEEPR_LOG_LEVEL=INFO
DEEPR_LOG_FORMAT=json
