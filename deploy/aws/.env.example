# Deepr AWS Deployment Configuration

# Required: ARN of a pre-created Secrets Manager secret.
# The JSON value may contain OPENAI_API_KEY, GOOGLE_API_KEY, and XAI_API_KEY.
# Provider keys never enter CloudFormation parameters or deployment history.
DEEPR_AWS_PROVIDER_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:deepr/prod/provider-keys-AbCdEf

# Budget limits (USD)
DEEPR_BUDGET_DAILY=10
DEEPR_BUDGET_MONTHLY=10

# AWS Configuration (for local testing)
AWS_REGION=us-east-1
AWS_PROFILE=default
DEEPR_ENVIRONMENT=prod
